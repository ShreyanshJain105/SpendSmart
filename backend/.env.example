# .env — local development environment variables
# Copy this file to .env and fill in your Supabase credentials.
# NEVER commit .env to git.

# ── Supabase Database ──────────────────────────────────────
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Transaction pooler" URI for serverless/short-lived connections:
# IMPORTANT: If your password contains special characters (e.g. @, #, $),
# you MUST percent-encode them. Example: @ → %40, # → %23, $ → %24
DATABASE_URL=postgresql://postgres.[YOUR-REF]:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:6543/postgres

# ── Flask ──────────────────────────────────────────────────
FLASK_ENV=development
